{
  "scenario_title": "常闇之廂",
  "initial_scene": "car_6",
  "setting": {
    "time_period": "2013年 (現代)",
    "visual_style": "現代化地鐵車廂",
    "atmosphere": "死寂、黑暗"
  },
  "global_vars": {
    "turn_count": 0,
    "flags": { "has_keys": false }
  },
  
  "item_database": {
    "rusty_keys": {
      "name": "生鏽的鑰匙",
      "description": "一把沉重的黃銅鑰匙，上面刻著『駕駛室』三個字。",
      "type": "key"
    },
    "newspaper": {
      "name": "明日報紙",
      "description": "日期是明天的報紙，頭條令人不安。",
      "type": "clue"
    }
  },

  "scenes": {
    "car_6": {
      "base_description": "你身處 6 號車廂。這是一節現代化的地鐵車廂。",
      "exits": {
        "car_5": { "keywords": ["前", "5號"], "target": "car_5" }
      },
      "interactables": {
        "sticky_note": {
          "keywords": ["便條", "紙條"],
          "description": "車門上貼著一張便條紙。",
          "type": "check",
          "skill": "Spot Hidden",
          "difficulty": 20,
          "on_success": [
            { "type": "narrate", "content": "你翻過便條紙背面，發現一行小字：『第三個箱子裡藏著鑰匙』。" }
          ],
          "on_fail": [
            { "type": "narrate", "content": "你看了看背面，什麼也沒發現。" }
          ]
        }
      }
    },
    
    "car_3": {
      "base_description": "這是 3 號車廂，滿地都是散落的行李。",
      "overlays": [
        { "condition": "has_keys == false", "text": "在雜亂的行李深處，似乎有個反光的金屬物體。" }
      ],
      "exits": {
        "car_6": { "keywords": ["後", "6號"], "target": "car_6" }
      },
      "interactables": {
        "luggage": {
          "keywords": ["行李", "反光", "鑰匙"],
          "description": "一堆雜亂的乘客行李。",
          "type": "check",
          "skill": "Spot Hidden",
          "difficulty": 20,
          
          "on_success": [
            { "type": "narrate", "content": "你在行李箱縫隙中找到了一串『駕駛室鑰匙』！" },
            { "type": "add_item", "id": "rusty_keys" },
            { "type": "set_flag", "key": "has_keys", "val": true }
          ],
          
          "on_fail": [
            { "type": "narrate", "content": "你翻了半天什麼都沒找到。" }
          ]
        }
      }
    }
  }
}